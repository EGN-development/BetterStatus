# Better Status — copy to .env and fill in

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/better_status?schema=public"

# Random secret — protects the internal cron endpoint & scopes tokens.
# Generate with: openssl rand -hex 32
APP_SECRET="change-me"

# Public base URL of this status page (used in notification links & feeds)
PUBLIC_URL="https://status.example.com"

# Port the server listens on (default 3000)
PORT=3000

# Set to 1 to disable the in-process check scheduler and instead drive checks
# externally via: POST /api/internal/tick   (Authorization: Bearer $APP_SECRET)
# DISABLE_SCHEDULER=0

# Optional fallback Telegram bot token for subscriber notifications
# (normally configured in Admin → Settings instead)
# TELEGRAM_BOT_TOKEN=
